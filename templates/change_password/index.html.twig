{% extends 'base.html.twig' %}

{% block title %}Change your Password!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>
{{ form_start(ChangePassForm) }}
    <section class="vh-100">
        <div class="container py-5 h-100">
            
        <div class="row d-flex align-items-center justify-content-center h-100">
        <div class="col-md-8 col-lg-7 col-xl-6">
            <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ"><img src="https://cdn.pixabay.com/photo/2016/06/03/09/57/password-1433096_960_720.png" class="img-fluid" alt="Phone image"></a>
        </div>

            
                    <div class="col-md-7 col-lg-5 col-xl-5 offset-xl-1">
                        
                    
                            
                                <h3 class="mb-0">Change Password</h3>
                            
                            
                                <form class="form" role="form" autocomplete="off">
                                    

                                    <!-- Password input -->
                                    <div class="form-group">
                                        <div class="form-outline mb-4">
                                            {{ form_row(ChangePassForm.password.first,  {
                                                'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Password '}, 
                                                label: 'New Password'
                                            }) }}
                                        </div>
                                        <span class="form-text small text-muted">
                                            The password must be 8-20 characters, and must <em>not</em> contain spaces.
                                        </span>
                                    </div>

                                    <!-- Verify Password input -->
                                    <div class="form-group">
                                        <div class="form-outline mb-4">
                                            {{ form_row(ChangePassForm.password.second, {
                                                'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Confirm Password'},
                                                label: 'Confirm Password :'
                                            }) }}
                                            <span class="form-text small text-muted">
                                                To confirm, type the new password again.
                                            </span>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <button type="submit" class="btn btn-primary btn-lg btn-block">Save</button>
                                    </div>
                                </form>
                            
                        </div>
                    </div>
                    <div class="col-md-6 offset-md-3">
                        <span class="anchor" id="formResetPassword"></span>
                        <hr class="mb-5">
                </div>
            </div>
        </div>

    </section>
{{ form_end(ChangePassForm) }}
{% endblock %}